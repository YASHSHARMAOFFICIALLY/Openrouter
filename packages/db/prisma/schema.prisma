// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model User {
  id Int @id @default(autoincrement())
  name String
  email String @unique
  password String 
  createdAt DateTime @default(now())
  credit    Int  @default(0)
  apiKeys  ApiKey[]
  onrampTranscitions OnrampTranscition[]
  converstaions converstion[]


}

model ApiKey {
  id Int @id @default(autoincrement())
  userId Int
  name String
  apiKey  String @unique
  disbaled Boolean @default(false)
  deleted Boolean @default(false)
  user   User   @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
converstions converstion[]

}

model Company {
  id Int @id @default(autoincrement())
  name String
  website String
  model Model[]
}

model Model {
  id Int @id @default (autoincrement())
  name String
  slug String
  companyId Int
  company Company @relation(fields:[companyId],references: [id])
  modelProviderMapping ModelProviderMapping[]
}



model Provider{
  id Int @id @default (autoincrement())
  name String
  Website String
  modelProviderMapping ModelProviderMapping[]

}

model ModelProviderMapping {
  id Int @id @default(autoincrement())
  modelId Int
  providerId Int
  inputTokenCost Int
  outputTokenCost Int 
  model Model @relation(fields: [modelId], references: [id])
  provider Provider @relation(fields: [providerId], references: [id])
  conversation converstion[]
}

model OnrampTranscition {
  id Int @id @default(autoincrement())
  userId Int
  amount Int
  createdAt DateTime @default(now())
  status String
  user User @relation(fields: [userId], references: [id])
}

model  converstion {
  id Int @id @default(autoincrement())
  userId Int 
  apiKeyId Int
  modelProviderMappingId Int
  input String
  output String
  inputTokenCount Int
  outputTokenCount Int
  createdAt DateTime @default(now())
  user User @relation(fields: [userId], references: [id])
  apiKey ApiKey @relation(fields: [apiKeyId], references: [id])
  modelProviderMapping ModelProviderMapping @relation(fields: [modelProviderMappingId], references:[id])
  

}